{
    "version": 2,
    "builds": [
        {
            "src": "src/main.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "src/main.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "src/main.js"
        }
    ]
}